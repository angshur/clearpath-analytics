---
import Layout from './Layout.astro';

export interface Props {
  title: string;
  description: string;
  date: Date;
  keywords?: string[];
  author?: string;
  readTime?: string;
}

const { title, description, date, keywords = [], author = 'Angshuman Rudra', readTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Layout title={title} description={description} keywords={keywords}>
  <div style="background:var(--cream-dark);border-bottom:1.5px solid var(--border);">
    <div style="max-width:760px;margin:0 auto;padding:64px 40px 52px;">

      <a href="/blog" style="display:inline-flex;align-items:center;gap:6px;font-size:14px;font-weight:500;color:var(--ink-mid);margin-bottom:40px;transition:color 0.15s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--ink-mid)'">
        ← Back to blog
      </a>

      <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap;">
        {keywords.slice(0, 2).map(k => (
          <span class="tag tag-amber">{k}</span>
        ))}
        <span style="font-size:13px;color:var(--ink-dim);">{formattedDate}</span>
        {readTime && <span style="font-size:13px;color:var(--ink-dim);">· {readTime} read</span>}
      </div>

      <h1 style="font-family:var(--font-serif);font-size:clamp(26px,4vw,38px);font-weight:700;letter-spacing:-0.01em;color:var(--ink);line-height:1.18;margin-bottom:18px;">{title}</h1>
      <p style="font-size:18px;color:var(--ink-mid);line-height:1.75;max-width:580px;">{description}</p>
    </div>
  </div>

  <div style="max-width:760px;margin:0 auto;padding:52px 40px 96px;">

    <div style="display:flex;align-items:center;gap:12px;padding:20px 0;border-bottom:1.5px solid var(--border);margin-bottom:52px;">
      <div style="width:40px;height:40px;border-radius:50%;background:var(--ink);display:flex;align-items:center;justify-content:center;font-family:var(--font-serif);font-weight:600;font-size:14px;color:var(--cream);border:2px solid var(--cream);box-shadow:2px 2px 0 var(--amber);">AR</div>
      <div>
        <div style="font-size:14px;font-weight:600;color:var(--ink);">{author}</div>
        <div style="font-size:13px;color:var(--ink-dim);">Marketing Intelligence Consultant</div>
      </div>
    </div>

    <div class="prose">
      <slot />
    </div>

    <div style="margin-top:72px;background:var(--ink);border-radius:var(--radius);padding:40px;text-align:center;box-shadow:5px 5px 0 var(--amber);">
      <span style="font-family:var(--font-accent);font-size:16px;color:rgba(250,247,242,0.5);display:block;margin-bottom:10px;">Work with me</span>
      <h3 style="font-family:var(--font-serif);font-size:22px;font-weight:600;color:var(--cream);margin-bottom:10px;">Ready to get clarity on your marketing data?</h3>
      <p style="font-size:15px;color:rgba(250,247,242,0.6);margin-bottom:24px;line-height:1.7;">Start with a Marketing Data Audit — two hours, $2,000 flat.</p>
      <a href="/#audit" class="btn-cream" style="font-size:15px;padding:11px 26px;margin:0 auto;">Book a Strategy Call →</a>
    </div>
  </div>
</Layout>
