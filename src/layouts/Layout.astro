---
export interface Props {
  title: string;
  description: string;
  keywords?: string[];
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  keywords = [],
  ogImage = '/og-default.png',
  canonical = Astro.url.href,
} = Astro.props;

const siteUrl = 'https://clearpath-analytics.vercel.app';
const fullTitle = title.includes('Clearpath') ? title : `${title} | Clearpath Analytics`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#FAF7F2" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
  <meta name="author" content="Angshuman Rudra" />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:site_name" content="Clearpath Analytics" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,500;0,600;0,700;1,500;1,600&family=DM+Sans:wght@300;400;500;600&family=Caveat:wght@600;700&display=swap" rel="stylesheet" />

  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">
      <div class="nav-logo-mark"><span>C</span></div>
      Clearpath Analytics
    </a>
    <ul class="nav-links">
      <li class="nav-dropdown">
        <button aria-haspopup="true" aria-expanded="false">
          Services <span class="nav-dropdown-caret">▾</span>
        </button>
        <ul class="dropdown-menu" role="menu">
          <li><span class="dropdown-group-label">For Marketing Leaders</span></li>
          <li><a href="/#services">Services overview</a></li>
          <div class="dropdown-divider"></div>
          <li><span class="dropdown-group-label">For Engineering &amp; Data Teams</span></li>
          <li><a href="/data-engineering">Data Engineering</a></li>
          <li><a href="/semantic-layer">Semantic Layer</a></li>
          <li><a href="/ai">AI Consulting</a></li>
        </ul>
      </li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/audit">AI Audit</a></li>
      <li><a href="/#about">About</a></li>
    </ul>
    <div style="display:flex;align-items:center;gap:10px;">
      <a href="/#audit" class="btn-primary">Book a Strategy Call →</a>
      <button class="nav-mobile-toggle" id="nav-toggle" aria-label="Toggle menu">☰</button>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div class="nav-mobile-menu" id="nav-mobile">
    <button class="nav-mobile-accordion-toggle" id="nav-services-toggle">
      Services
      <span id="nav-services-caret" style="font-size:12px;transition:transform 0.15s;">▾</span>
    </button>
    <div class="nav-mobile-accordion-body" id="nav-services-body">
      <span class="nav-mobile-group-label">For Marketing Leaders</span>
      <a href="/#services" class="nav-mobile-sub-link">Services overview</a>
      <span class="nav-mobile-group-label">For Engineering &amp; Data Teams</span>
      <a href="/data-engineering" class="nav-mobile-sub-link">Data Engineering</a>
      <a href="/semantic-layer" class="nav-mobile-sub-link">Semantic Layer</a>
      <a href="/ai" class="nav-mobile-sub-link">AI Consulting</a>
    </div>
    <a href="/blog" class="nav-mobile-link">Blog</a>
    <a href="/audit" class="nav-mobile-link">AI Audit</a>
    <a href="/#about" class="nav-mobile-link">About</a>
    <div style="margin-top:16px;">
      <a href="/#audit" class="btn-primary" style="width:100%;justify-content:center;">Book a Strategy Call →</a>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('nav-toggle');
    const mobileMenu = document.getElementById('nav-mobile');
    const servicesToggle = document.getElementById('nav-services-toggle');
    const servicesBody = document.getElementById('nav-services-body');
    const servicesCaret = document.getElementById('nav-services-caret');

    toggle?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('open');
    });

    servicesToggle?.addEventListener('click', () => {
      servicesBody?.classList.toggle('open');
      if (servicesCaret) {
        servicesCaret.style.transform = servicesBody?.classList.contains('open') ? 'rotate(180deg)' : '';
      }
    });

    // Close mobile nav when a link is clicked
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu.classList.remove('open'));
    });
  </script>

  <main>
    <slot />
  </main>

  <div style="max-width: var(--max-w); margin: 0 auto;">
    <footer>
      <a href="/" class="nav-logo" style="font-size:15px;">
        <div class="nav-logo-mark"><span>C</span></div>
        Clearpath Analytics
      </a>
      <ul class="footer-links">
        <li><a href="/#services">Services</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="https://www.linkedin.com/in/angshumanrudra/" target="_blank" rel="noopener">LinkedIn</a></li>
      </ul>
      <p>© 2026 Clearpath Analytics</p>
    </footer>
  </div>
</body>
</html>
