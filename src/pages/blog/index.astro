---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Blog — Marketing Data & Analytics | Clearpath Analytics"
  description="Deep dives on marketing attribution, media mix modeling, data engineering, and the tools modern marketing teams actually need."
  keywords={['marketing analytics blog', 'attribution modeling', 'media mix modeling', 'marketing data engineering']}
>
  <section style="background:var(--cream-dark);border-bottom:1.5px solid var(--border);">
    <div style="max-width:var(--max-w);margin:0 auto;padding:72px 48px 56px;">
      <span class="section-label">Blog</span>
      <h1 style="font-size:clamp(30px,4vw,46px);margin-bottom:14px;">Marketing data, explained plainly.</h1>
      <p style="font-size:18px;color:var(--ink-mid);max-width:500px;line-height:1.75;">Technical depth on attribution, MMM, data pipelines, and the questions CMOs actually need answered.</p>
    </div>
  </section>

  <div style="max-width:var(--max-w);margin:0 auto;padding:0 48px 96px;">
    {posts.map((post, i) => (
      <a
        href={`/blog/${post.slug}`}
        style={`display:grid;grid-template-columns:1fr auto;gap:24px;align-items:start;padding:36px 0;border-bottom:1.5px solid var(--border);text-decoration:none;transition:all 0.15s;${i===0?'border-top:1.5px solid var(--border);margin-top:0;':''}`}
      >
        <div>
          <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
            {(post.data.keywords ?? []).slice(0, 3).map((k: string) => (
              <span class="tag tag-amber">{k}</span>
            ))}
          </div>
          <h2 style="font-size:20px;color:var(--ink);margin-bottom:10px;line-height:1.3;">{post.data.title}</h2>
          <p style="font-size:15px;color:var(--ink-mid);line-height:1.7;max-width:600px;">{post.data.description}</p>
        </div>
        <div style="text-align:right;flex-shrink:0;">
          <div style="font-size:13px;color:var(--ink-dim);margin-bottom:8px;white-space:nowrap;">
            {post.data.date.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
          </div>
          <span style="font-family:var(--font-accent);font-size:16px;font-weight:600;color:var(--amber);">Read →</span>
        </div>
      </a>
    ))}
  </div>
</Layout>
