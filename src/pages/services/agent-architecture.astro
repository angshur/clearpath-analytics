---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Agent Architecture for Marketing Teams"
  description="Design the agent stack: which workflows automate, how orchestration works, how governance is enforced."
>
  <div style="max-width:var(--max-w);margin:0 auto;padding:96px 48px;">
    <a href="/" style="font-size:14px;color:var(--ink-mid);text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-bottom:40px;">← Back</a>
    <span class="section-label">Services</span>
    <h1 style="font-family:var(--font-serif);font-size:clamp(32px,4vw,48px);font-weight:700;margin-bottom:16px;letter-spacing:-0.02em;">Agent Architecture for Marketing Teams</h1>
    <p style="font-size:18px;color:var(--ink-mid);max-width:540px;line-height:1.75;">Full details coming soon. <a href="/#contact" style="color:var(--amber);">Get in touch →</a></p>
  </div>
</Layout>
